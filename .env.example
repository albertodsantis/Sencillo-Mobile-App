# Frontend -> API
# Use this in local dev (or your real API URL in production).
EXPO_PUBLIC_API_URL=http://localhost:5000

# Optional fallback for native Expo Go when API URL is not set.
EXPO_PUBLIC_API_PORT=5000

# Build/deploy domain used by scripts/build.js (without protocol is fine).
# Example: app.tudominio.com
DEPLOYMENT_DOMAIN=
EXPO_PUBLIC_DOMAIN=

# Backend
PORT=5000
# Comma-separated full origins allowed by CORS.
# Example: http://localhost:8081,https://app.tudominio.com
CORS_ORIGINS=http://localhost:8081

# Database
DATABASE_URL=

# Supabase (client-side)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Crash reporting (client-side)
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENVIRONMENT=production
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Crash reporting (build-time / sourcemaps)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_URL=https://sentry.io/
